{
  "version": 2,
  "routes": [
    {
      "src": "/api/admin/(.*)",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "dest": "/api/admin/$1"
    },
    {
      "src": "/api/(.*)",
      "methods": ["POST", "OPTIONS"],
      "dest": "/api/$1"
    },
    {
      "src": "/admin",
      "dest": "/admin/index.html"
    }
  ]
}
